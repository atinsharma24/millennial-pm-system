# Database (PostgreSQL for Render/production; switch provider in schema.prisma for local MySQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/millennial_pm"

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (Ethereal for dev — auto-generated if left empty)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Millennial PM <noreply@millennialcompany.in>"

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# API internal base URL (used by scheduler worker)
API_BASE_URL=http://localhost:4000
